# ------------------------------------------------------------------
# Backstage Path — variables d'environnement
# Copiez ce fichier en `.env` : cp .env.example .env
# ------------------------------------------------------------------

# Base de données.
# Par défaut : SQLite local (aucune installation externe requise).
DATABASE_URL="file:./dev.db"

# Pour passer à PostgreSQL / Supabase, remplacez par :
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
# ...et changez `provider = "sqlite"` -> `provider = "postgresql"` dans prisma/schema.prisma

# Secret utilisé pour signer les sessions. Générez-en un :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-in-production-please-use-a-long-random-string"

# ------------------------------------------------------------------
# Connecteurs optionnels (non requis pour faire tourner l'app).
# Laissez vide pour utiliser le mode heuristique / démo intégré.
# ------------------------------------------------------------------

# Clé API d'un modèle de langage (fonctionnalités IA "réelles").
# Sans clé, l'app utilise un moteur heuristique local, honnête et hors-ligne.
ANTHROPIC_API_KEY=""

# Secret protégeant l'endpoint de tâches planifiées /api/cron.
# Le planificateur doit envoyer : Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# Connecteurs futurs (Google Drive / Calendar / Gmail / Sheets / Notion) :
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NOTION_TOKEN=""
