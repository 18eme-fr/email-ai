# --- Salin Radio environment variables -------------------------------------
# Copy this file to .env.local and fill in the values you have. Every value
# below is optional: without them, Salin Radio runs fully in demo mode using
# the seed catalog in src/lib/mock-videos.ts, an in-memory data store, and a
# rule-based AI scorer (src/lib/ai.ts).

# YouTube Data API v3 key. Without it, the admin "search YouTube" workflow
# returns a small set of mock candidates instead of live results.
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

# OpenAI API key used to analyze candidate videos (summary, mood, tags,
# rarity/quality/discovery/sample scores, accept/hold/reject decision).
# Without it, src/lib/ai.ts falls back to a heuristic scorer.
OPENAI_API_KEY=

# Supabase / PostgreSQL. Without these, Salin Radio uses an in-memory demo
# store seeded from src/lib/mock-videos.ts (see supabase/schema.sql for the
# table definitions to run once you provision a project).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Public URL of the deployed app (used for metadata/OG tags).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Admin authentication ---------------------------------------------------
# Single admin account for /admin. Defaults below are for local demo use only
# — always set real values before deploying.
ADMIN_EMAIL=admin@salinradio.demo
ADMIN_PASSWORD=salinradio-demo
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string
